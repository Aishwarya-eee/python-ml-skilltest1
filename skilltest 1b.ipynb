    "import numpy as np\n",
    "\n",
    "\n",
    "A = np.array([[2, 3],\n",
    "              [1, 2]])\n",
    "\n",
    "\n",
    "b = np.array([8, 5])\n",
    "\n",
    "\n",
    "x = np.linalg.solve(A, b)\n",
    "\n",
    "\n",
    "print(\"Solution vector x:\")\n",
    "print(x)"
   ]
  }
